[Unit]
Description=Ouroboros BTC Critic — weekly performance evaluator
After=network-online.target

[Service]
Type=oneshot
User=ubuntu
WorkingDirectory=/home/ubuntu/trading_bot/MAIN
ExecStart=/home/ubuntu/trading_bot/MAIN/.venv/bin/python tools/weekly_btc_critic.py
StandardOutput=append:/home/ubuntu/trading_bot/MAIN/tools/critic.log
StandardError=append:/home/ubuntu/trading_bot/MAIN/tools/critic.log
