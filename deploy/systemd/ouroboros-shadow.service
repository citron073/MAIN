[Unit]
Description=Ouroboros shadow paper runner
After=network-online.target
Wants=network-online.target
ConditionPathExists=/home/ubuntu/trading_bot/trading_bot/MAIN/CONTROL_shadow.csv

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/trading_bot/trading_bot/MAIN
Environment=PYTHONUNBUFFERED=1
EnvironmentFile=-/etc/ouroboros/secrets.env
Environment=OUROBOROS_INSTANCE=shadow
Environment=OUROBOROS_CONTROL_PATH=/home/ubuntu/trading_bot/trading_bot/MAIN/CONTROL_shadow.csv
Environment=OUROBOROS_RUN_LOCK_PATH=/home/ubuntu/trading_bot/trading_bot/MAIN/.run_lock_shadow
ExecStart=/home/ubuntu/trading_bot/trading_bot/MAIN/.venv/bin/python run.py --interval 60 --print-tick
StandardOutput=append:/home/ubuntu/trading_bot/trading_bot/MAIN/run_shadow.log
StandardError=append:/home/ubuntu/trading_bot/trading_bot/MAIN/run_shadow.log
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
